[gd_scene format=3 uid="uid://dujdxpoa3uf4w"]

[sub_resource type="GDScript" id="GDScript_pu0qw"]
script/source = "# ui/pause_menu.gd
extends CanvasLayer

@onready var resume_button: Button = %ResumeButton
@onready var save_button: Button = %SaveButton
@onready var debug_print_button: Button = %DebugPrintButton
@onready var debug_reset_button: Button = %DebugResetButton
@onready var quit_button: Button = %QuitButton
@onready var feedback_label: Label = %FeedbackLabel

var is_open: bool = false

func _ready() -> void:
	visible = false
	feedback_label.visible = false
	process_mode = PROCESS_MODE_ALWAYS
	
	resume_button.pressed.connect(_on_resume)
	save_button.pressed.connect(_on_save)
	debug_print_button.pressed.connect(_on_debug_print)
	debug_reset_button.pressed.connect(_on_debug_reset)
	quit_button.pressed.connect(_on_quit)
	
	InputManager.menu_toggled.connect(_on_menu_toggled)
	

func _on_menu_toggled() -> void:
	if is_open:
		_on_resume()
	else:
		open_menu()

func open_menu() -> void:
	if is_open:
		return
	is_open = true
	Global.is_in_menu = true
	InputManager.block_input()
	visible = true

func _on_resume() -> void:
	is_open = false
	Global.is_in_menu = false
	InputManager.unblock_input()
	visible = false
	feedback_label.visible = false

func _on_save() -> void:
	if SaveManager:
		Global.is_death_respawn = false
		SaveManager.request_save()
		_show_feedback(\"Game Saved ✓\", 1.5, Color(0.2, 1.0, 0.3))
	else:
		_show_feedback(\"SaveManager missing!\", 2.0, Color.RED)

func _on_debug_print() -> void:
	if WorldStateManager:
		print(\"\\n=== WORLD STATE DEBUG ===\")
		for path in WorldStateManager.world_state:
			var s = WorldStateManager.world_state[path]
			print(\"Scene: \", path.get_file())
			print(\" Regular dead: \", s.get(\"regular_dead_enemies\", []))
			print(\" Permanent: \", s.get(\"permanent\", {}))
		_show_feedback(\"World state printed\", 2.0)
	else:
		_show_feedback(\"WorldStateManager missing\", 2.0, Color.RED)

func _on_debug_reset() -> void:
	if WorldStateManager:
		WorldStateManager.reset_all_regular_enemies()
		_show_feedback(\"Regular enemies reset\", 2.0)
	else:
		_show_feedback(\"WorldStateManager missing\", 2.0, Color.RED)

func _on_quit() -> void:
	_on_resume()
	if SaveManager:
		SaveManager.request_save()
	get_tree().change_scene_to_file(\"res://scenes/ui/man_menu.tscn\")

func _show_feedback(text: String, duration: float = 2.0, color: Color = Color(0.2, 1.0, 0.3)) -> void:
	feedback_label.modulate = color
	feedback_label.text = text
	feedback_label.visible = true
	var timer = get_tree().create_timer(duration)
	timer.timeout.connect(_hide_feedback)

func _hide_feedback() -> void:
	feedback_label.visible = false

# ─── Input handling ─────────────────────────────────────────────────────
func _input(event: InputEvent) -> void:
	if not visible:
		return
	
	if event.is_action_pressed(\"ui_cancel\") or event.is_action_pressed(\"menu_pause\"):
		_on_resume()
		get_viewport().set_input_as_handled()
"

